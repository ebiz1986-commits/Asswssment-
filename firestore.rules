rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /candidates/{candidateId} {
      allow read, write: if request.auth != null && request.auth.token.email.matches('(?i).*@sankenoverseas\\.com');
    }
    match /user_profiles/{email} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.token.email.matches('(?i).*@sankenoverseas\\.com');
      allow write: if request.auth != null && request.auth.token.email.matches('(?i).*@sankenoverseas\\.com');
    }
  }
}
